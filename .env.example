# API Keys and Environment Variables
# Copy this file to .env and fill in your credentials as needed

# Kalshi authenticated request settings
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_TIMEOUT_SECONDS=30
KALSHI_SLEEP_SECONDS=0.15

POLYMARKET_API_KEY=
ODDS_API_KEY=

# Logging
LOG_LEVEL=INFO
